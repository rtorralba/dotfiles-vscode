#!/bin/bash

echo "Setting up workspace folder: $WORKSPACE_FOLDER"
cd $WORKSPACE_FOLDER
rm -rf $WORKSPACE_FOLDER/.vscode/*
cp "$HOME/dotfiles/.vscode/extensions.json" $WORKSPACE_FOLDER/.vscode/
cp "$HOME/dotfiles/.vscode/settings.json" $WORKSPACE_FOLDER/.vscode/
mkdir "$HOME/.config"
ln -s "$HOME/dotfiles/.config/phpactor" "$HOME/.config/phpactor"
